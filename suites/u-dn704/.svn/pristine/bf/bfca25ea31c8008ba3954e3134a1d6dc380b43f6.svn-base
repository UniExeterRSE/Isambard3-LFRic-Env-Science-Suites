[jinja2:suite.rc=EX_HOST]
compulsory=true
description=MetOffice EXAB Host
help=Which EX host zone to use. Options are exab (Default), excd or exz
sort-key=1d
type=str

[jinja2:suite.rc=MIRROR_LOC]
compulsory=false
description=Location of github mirrors
help=HostName:Path format, pointing at github mirrors. Required if USE_MIRRORS
    =is true.
    =Default value is valid for MetOffice workflows
sort-key=1d
type=str

[jinja2:suite.rc=USE_MIRRORS]
compulsory=true
description=Use local github mirrors
help=Use local github mirrors to clone sources from. Default is true
sort-key=1d
type=boolean

[jinja2:suite.rc=USE_TOKENS]
compulsory=true
description=Github Authentication via github PATs
help=If true, switches sources to use https urls instead of ssh. This requires
    =a github personal access token to be setup to authenticate with github.
    =Default is false
sort-key=1d
type=boolean
